# Web dashboard URL (where the Next.js app is running)
# Agent will send reports to: $DDNS_BACKEND_URL/api/servers
DDNS_BACKEND_URL=http://localhost:3000

# API Key for authentication (REQUIRED)
# Generate a random key or use: openssl rand -hex 32
DDNS_API_KEY=your-secret-api-key-here

# Report interval (e.g., 30s, 1m, 5m)
DDNS_UPDATE_INTERVAL=30s
